# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here
LEADERBOARD_CHAT_IDS=-100111111111,-100222222222

# Groq API (free tier — get key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Proxmox Configuration
PROXMOX_HOST=192.168.1.100:8006
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your_proxmox_password_here

# Optional: Proxmox SSL Verification (set to false for self-signed certificates)
PROXMOX_VERIFY_SSL=false
